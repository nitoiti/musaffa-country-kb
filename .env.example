# Neon Postgres (from Neon dashboard → Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Google OAuth (Google Cloud Console → APIs & Credentials)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Comma-separated @musaffa.com emails that get ADMIN on first sign-in
ADMIN_EMAILS="you@musaffa.com"

# Public URL (Vercel sets this automatically in production)
AUTH_URL="http://localhost:3000"
