{
  "name": "musaffa-country-kb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/clean-dev.js && next dev",
    "verify": "node scripts/verify-dev.js",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "build:countries": "python scripts/build-countries.py",
    "import:tier1": "python scripts/import-tier1-research.py",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
